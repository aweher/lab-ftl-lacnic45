# ============================================================
# Edgeshark — variables de entorno
# Copialo a `.env` y ajustá lo necesario:
#   cp env.example .env
# (el .env NO se commitea, está en .gitignore)
# ============================================================

# Puerto local (loopback) donde se publica la UI de Edgeshark.
# Lo bindeamos a 127.0.0.1 a propósito: NO se expone a internet.
# Para acceder desde afuera, configurá Cloudflare Tunnel apuntando a este puerto.
EDGESHARK_PORT=19831
